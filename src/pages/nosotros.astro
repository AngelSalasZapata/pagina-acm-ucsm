---
// src/pages/nosotros.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Nosotros">

    <!-- ABOUT -->
  <section class="about section" id="about">
    <div class="container">
      <div class="section-label">// 01. QUIÉNES SOMOS</div>
      <div class="about-grid">
        <div class="about-text">
          <h2 class="section-title">Impulsando el futuro <span class="accent">tecnológico</span> del Perú</h2>
          <p>Somos el capítulo estudiantil de la <strong>Association for Computing Machinery (ACM)</strong> de la UCSM, una comunidad de estudiantes apasionados por la ciencia de la computación, el desarrollo de software y la innovación tecnológica.</p>
          <p>Fundado para conectar a estudiantes con recursos académicos de clase mundial, organizamos talleres, hackathons, charlas con la industria y proyectos colaborativos que potencian las habilidades técnicas y profesionales de nuestros miembros.</p>
          <p>Formamos parte de la red global ACM con presencia en más de 100 países, brindando a nuestros miembros acceso a publicaciones científicas, eventos internacionales y una comunidad diversa de profesionales.</p>
          <div class="about-badges">
            <span class="badge">Programación</span>
            <span class="badge">IA &amp; ML</span>
            <span class="badge">Ciberseguridad</span>
            <span class="badge">Open Source</span>
            <span class="badge">Redes</span>
            <span class="badge">Robótica</span>
          </div>
        </div>
        <div class="stat-grid">
          <div class="stat-card">
            <div class="stat-num-big">120+</div>
            <div class="stat-label-card">MIEMBROS ACTIVOS</div>
          </div>
          <div class="stat-card">
            <div class="stat-num-big">3°</div>
            <div class="stat-label-card">AÑO CONSECUTIVO</div>
          </div>
          <div class="stat-card">
            <div class="stat-num-big">40+</div>
            <div class="stat-label-card">EVENTOS AL AÑO</div>
          </div>
          <div class="stat-card">
            <div class="stat-num-big">8</div>
            <div class="stat-label-card">PROYECTOS ACTIVOS</div>
          </div>
        </div>
      </div>
    </div>
  </section>
  <script type="module" src="/src/scripts/nosotros.js"></script>
</BaseLayout>